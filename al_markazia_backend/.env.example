# ── Core ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database (PostgreSQL) ────────────────────────────
# Local development example:
DATABASE_URL="postgresql://admin:password123@localhost:5432/al_markazia_db?schema=public&connection_limit=20"

# ── Authentication ───────────────────────────────────
# IMPORTANT: Use strong, unique secrets for each.
# Generate via: openssl rand -base64 48
JWT_SECRET=                # 32+ chars, randomly generated
REFRESH_TOKEN_SECRET=      # 32+ chars, randomly generated, MUST be different from JWT_SECRET

# Token Expiry (Standard JWT duration strings: '15m', '1h', '7d')
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ── Redis (BullMQ + Cache) ───────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── CORS ─────────────────────────────────────────────
# Comma-separated list of allowed origins:
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ── Logging ──────────────────────────────────────────
# Levels: debug | http | info | warn | error
LOG_LEVEL=debug

# ── Firebase (FCM) ───────────────────────────────────
# Place the entire content of your service-account.json as a single-line JSON string
FIREBASE_SERVICE_ACCOUNT=

# ── Internal Scripts ─────────────────────────────────
# HOST_IP is auto-synced by scripts/sync-ip.js
HOST_IP=127.0.0.1
