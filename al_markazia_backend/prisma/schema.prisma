generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  phone     String?  @unique
  name      String?
  password  String
  role      String   @default("admin")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  fcmToken  String?
  uuid      String   @unique @default(uuid())
}

model Category {
  id            Int     @id @default(autoincrement())
  name          String
  nameEn        String?
  description   String?
  descriptionEn String?
  image         String?
  isActive      Boolean @default(true)
  sortOrder     Int     @default(0)
  items         Item[]
}

model Item {
  id                Int               @id @default(autoincrement())
  title             String
  titleEn           String?
  description       String?
  descriptionEn     String?
  basePrice         Decimal           @db.Decimal(10, 2)
  image             String?
  categoryId        Int
  isAvailable       Boolean           @default(true)
  isFeatured        Boolean           @default(false)
  preparationTime   Int?
  createdAt         DateTime          @default(now())
  cachedAvgRating   Float?            @default(0)
  cachedReviewCount Int?              @default(0)
  excludeFromStats  Boolean           @default(false)
  category          Category          @relation(fields: [categoryId], references: [id])
  optionGroups      ItemOptionGroup[]
  orderItems        OrderItem[]
  reviews           Review[]

  @@index([categoryId, isAvailable])
  @@index([isAvailable, createdAt])
}

model ItemOptionGroup {
  id          Int          @id @default(autoincrement())
  itemId      Int
  groupName   String
  groupNameEn String?
  type        String       @default("SINGLE")
  isRequired  Boolean      @default(false)
  isActive    Boolean      @default(true)
  minSelect   Int          @default(0)
  maxSelect   Int          @default(1)
  sortOrder   Int          @default(0)
  options     ItemOption[]
  item        Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model ItemOption {
  id          Int             @id @default(autoincrement())
  groupId     Int
  name        String
  nameEn      String?
  price       Decimal         @default(0) @db.Decimal(10, 2)
  isDefault   Boolean         @default(false)
  isAvailable Boolean         @default(true)
  sortOrder   Int             @default(0)
  group       ItemOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Order {
  id               Int                @id @default(autoincrement())
  orderNumber      String             @unique
  customerName     String
  customerPhone    String
  customerId       Int?
  orderType        String
  status           String             @default("pending")
  paymentStatus    String             @default("unpaid")
  paymentMethod    String             @default("cash")
  subtotal         Decimal            @default(0) @db.Decimal(10, 2)
  deliveryFee      Decimal            @default(0) @db.Decimal(10, 2)
  discount         Decimal            @default(0) @db.Decimal(10, 2)
  tax              Decimal            @default(0) @db.Decimal(10, 2)
  total            Decimal            @default(0) @db.Decimal(10, 2)
  address                String?
  notes                  String?
  estimatedReadyAt       DateTime?
  estimatedArrivalAt     DateTime?
  preparationTimeMinutes Int?               @default(20)
  deliveryTimeMinutes    Int?               @default(15)
  rating                 Int?
  ratingComment          String?
  isRatingApproved       Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  branch                 String?
  version          Int                @default(1)
  deliveryMinOrder Decimal?           @db.Decimal(10, 2)
  deliveryZoneId   String?
  deliveryZoneName String?
  tenantId         String?            @default("default-restaurant")
  customer         Customer?          @relation(fields: [customerId], references: [id])
  source           String             @default("app") // app, manual
  auditLogs        OrderAuditLog[]
  cancellation     OrderCancellation?
  orderItems       OrderItem[]
  payment          Payment?
  reviews          Review[]

  @@index([status, createdAt(sort: Desc)])
  @@index([customerId, createdAt(sort: Desc)])
  @@index([orderNumber])
  @@index([createdAt])
  @@index([tenantId])
}

model Event {
  id            String   @id @default(uuid())
  type          String
  aggregateId   Int
  aggregateType String   @default("order")
  payload       Json
  metadata      Json?
  version       Int
  tenantId      String?  @default("default-restaurant")
  createdAt     DateTime @default(now())

  @@index([aggregateId])
  @@index([type])
  @@index([tenantId])
  @@index([createdAt])
}

model OrderItem {
  id                Int             @id @default(autoincrement())
  orderId           Int
  itemId            Int?
  itemName          String
  itemNameEn        String?
  quantity          Int             @default(1)
  unitPrice         Decimal         @db.Decimal(10, 2)
  selectedOptions   String?
  selectedOptionsEn String?
  lineTotal         Decimal         @db.Decimal(10, 2)
  notes             String?
  status            OrderItemStatus @default(normal)
  rejectionReason   String?
  item              Item?           @relation(fields: [itemId], references: [id])
  order             Order           @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([itemId])
}

model Customer {
  id                  Int                @id @default(autoincrement())
  name                String
  phone               String?            @unique
  email               String?            @unique
  password            String?
  address             String?
  fcmToken            String?
  points              Int                @default(0)
  totalOrders         Int                @default(0)
  tier                String             @default("SILVER") // SILVER, GOLD, PLATINUM
  cancellationCount   Int                @default(0)
  isBlacklisted       Boolean            @default(false)
  blacklistedAt       DateTime?
  blacklistExpiresAt  DateTime?
  blacklistUntil      DateTime?
  blacklistReason     String?
  blacklistReasonCode String?
  blacklistSource     String?
  blacklistedBy       String?
  blacklistSeverity   String             @default("LOW")
  riskScore           Float              @default(0)
  riskScoreUpdatedAt  DateTime?
  createdAt           DateTime           @default(now())
  emailVerifiedAt     DateTime?
  phoneVerifiedAt     DateTime?
  username            String?            @unique
  uuid                String             @unique @default(uuid())
  auditLogs           CustomerAuditLog[]
  orders              Order[]
  reviews             Review[]

  @@index([isBlacklisted])
}

model Payment {
  id             Int       @id @default(autoincrement())
  orderId        Int       @unique
  method         String
  amount         Decimal   @db.Decimal(10, 2)
  status         String
  transactionRef String?
  paidAt         DateTime?
  order          Order     @relation(fields: [orderId], references: [id])
}

model Notification {
  id            Int      @id @default(autoincrement())
  customerPhone String?
  title         String
  titleEn       String?
  message       String
  messageEn     String?
  type          String
  isRead        Boolean  @default(false)
  orderId       Int?
  targetRoute   String?
  createdAt     DateTime @default(now())
  fcmSent       Boolean  @default(false)
  lastError     String?
  metadata      Json?
  retryCount    Int      @default(0)
  socketSent    Boolean  @default(false)
  status        String   @default("PENDING")
  updatedAt     DateTime @default(now()) @updatedAt

  @@index([customerPhone])
  @@index([status])
  @@index([createdAt])
}

model Review {
  id                 Int      @id @default(autoincrement())
  itemId             Int
  rating             Int
  comment            String?  @db.VarChar(500)
  isApproved         Boolean  @default(true)
  createdAt          DateTime @default(now())
  customerId         Int
  ipAddress          String?
  isFlagged          Boolean  @default(false)
  isVerifiedPurchase Boolean  @default(false)
  orderId            Int?
  updatedAt          DateTime @updatedAt
  userAgent          String?
  customer           Customer @relation(fields: [customerId], references: [id])
  item               Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  order              Order?   @relation(fields: [orderId], references: [id])

  @@unique([customerId, itemId])
  @@index([itemId, isApproved, createdAt(sort: Desc)])
  @@index([customerId, createdAt])
}

model OrderCancellation {
  id              Int      @id @default(autoincrement())
  orderId         Int      @unique
  reason          String
  cancelledBy     String
  previousStatus  String
  status          String   @default("pending")
  rejectionReason String?
  adminName       String?
  createdAt       DateTime @default(now())
  order           Order    @relation(fields: [orderId], references: [id])
}

model SystemSettings {
  id                      Int      @id @default(autoincrement())
  key                     String   @unique
  value                   String
  updatedAt               DateTime @updatedAt
  freeCancelWindowMinutes Int      @default(5)
  spamCancelLimit         Int      @default(3)
  spamTimeWindowMinutes   Int      @default(30)
  defaultDeliveryFee      Decimal  @default(1.00) @db.Decimal(10, 2)
}

model OrderAuditLog {
  id              Int      @id @default(autoincrement())
  orderId         Int
  eventType       String
  eventAction     String
  changedBy       String
  changedByRole   String
  previousData    String?
  newData         String?
  changedFields   String?
  rejectionReason String?
  integrityHash   String?
  createdAt       DateTime @default(now())
  order           Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([createdAt])
  @@index([eventType])
}

model OrderAuditLogArchive {
  id              Int      @id @default(autoincrement())
  orderId         Int
  eventType       String
  eventAction     String
  changedBy       String
  changedByRole   String
  previousData    String?
  newData         String?
  changedFields   String?
  rejectionReason String?
  integrityHash   String?
  createdAt       DateTime @default(now())
}

model IdempotencyRecord {
  id           Int      @id @default(autoincrement())
  key          String   @unique
  status       String   @default("processing")
  responseCode Int?
  responseBody String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([expiresAt])
}

model NotificationLog {
  id          Int       @id @default(autoincrement())
  orderId     Int
  customerId  Int?
  type        String
  status      String    @default("pending")
  error       String?
  retries     Int       @default(0)
  maxRetries  Int       @default(3)
  nextRetryAt DateTime?
  createdAt   DateTime  @default(now())
}

model CustomerAuditLog {
  id               Int      @id @default(autoincrement())
  customerId       Int
  eventType        String
  eventAction      String
  changedBy        String
  changedByRole    String
  reason           String?
  previousData     String?
  newData          String?
  diff             String?
  severitySnapshot String?
  requestId        String?
  actionCategory   String   @default("CUSTOMER_MODERATION")
  userAgent        String?
  deviceId         String?
  requestSource    String?
  ip               String?
  createdAt        DateTime @default(now())
  customer         Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([createdAt])
}

model DeliveryZone {
  id        String   @id @default(uuid())
  nameAr    String   @unique
  nameEn    String?
  fee       Decimal  @db.Decimal(10, 2)
  minOrder  Decimal? @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  role      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isRevoked Boolean  @default(false)

  @@index([userId])
  @@index([token])
}

model HealthMetric {
  id        Int      @id @default(autoincrement())
  score     Int
  status    String
  services  Json
  latencies Json
  errorRate Float?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([status])
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String?
  email     String?
  codeHash  String
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  purpose   String   @default("login")
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?
  metadata  Json?

  @@index([phone, purpose, used])
  @@index([email, purpose, used])
  @@index([expiresAt])
}

model SystemAuditLog {
  id           String   @id @default(uuid())
  userId       String?  // Can be User uuid or Customer uuid
  userRole     String?
  action       String
  ip           String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model RestaurantSettings {
  id                          Int       @id @default(1)
  timezone                    String    @default("Asia/Amman")
  isEmergencyClosed           Boolean   @default(false)
  closureReason               String?
  reopenAt                    DateTime?
  lastOrderMinutesBeforeClose Int       @default(15) // Grace Period
  updatedAt                   DateTime  @updatedAt
}

model WorkingHour {
  id        Int      @id @default(autoincrement())
  dayOfWeek Int      // 0 (Sunday) to 6 (Saturday)
  openTime  String   // "HH:mm" e.g., "09:00"
  closeTime String   // "HH:mm" e.g., "23:00"
  isClosed  Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@unique([dayOfWeek])
}

enum OrderItemStatus {
  normal
  pending_partial_cancel
  cancelled
  rejected
}

model LoyaltyConfig {
  id                      Int      @id @default(1)
  pointsPerJod            Float    @default(10)
  tierGoldMinOrders       Int      @default(10)
  tierPlatinumMinOrders   Int      @default(25)
  pointsMultiplierGold    Float    @default(1.5)
  pointsMultiplierPlatinum Float    @default(2.0)
  reviewPoints            Int      @default(50)
  referralPoints          Int      @default(100)
  socialSharePoints       Int      @default(20)
  happyHourMultiplier     Float    @default(2.0)
  happyHourStart          String   @default("16:00")
  happyHourEnd            String   @default("18:00")
  isHappyHourEnabled      Boolean  @default(false)
  updatedAt               DateTime @updatedAt
}

model RestaurantSubscription {
  id          Int      @id @default(autoincrement())
  userId      String?
  fcmToken    String
  targetTime  DateTime
  notified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([notified, targetTime])
}
