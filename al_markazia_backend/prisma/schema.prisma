datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- Users & Access ---
model User {
  id           Int           @id @default(autoincrement())
  uuid         String        @unique @default(uuid())
  email        String        @unique
  password     String
  role         String        @default("admin") // admin only as per requirement
  isActive     Boolean       @default(true)
  fcmToken     String?       // New: For targeted admin push alerts
  createdAt    DateTime      @default(now())
}

// --- Menu Management ---
model Category {
  id          Int      @id @default(autoincrement())
  name        String
  nameEn      String?  // English translation
  description String?
  descriptionEn String? // English translation
  image       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  items       Item[]
}

model Item {
  id              Int          @id @default(autoincrement())
  title           String
  titleEn         String?      // English translation
  description     String?
  descriptionEn   String?      // English translation
  basePrice       Decimal      @db.Decimal(10, 2) // Renamed from price to basePrice for professional use
  image           String?      // URL of the uploaded image
  categoryId      Int
  isAvailable     Boolean      @default(true)
  isFeatured      Boolean      @default(false)
  excludeFromStats Boolean     @default(false) // 🚀 New: Persist dashboard exclusions
  preparationTime Int?         // In minutes
  createdAt       DateTime     @default(now())
  category        Category          @relation(fields: [categoryId], references: [id])
  optionGroups    ItemOptionGroup[]
  orderItems      OrderItem[]
  reviews         Review[]
}

model ItemOptionGroup {
  id          Int          @id @default(autoincrement())
  itemId      Int
  groupName   String
  groupNameEn String?      // English translation
  type        String       @default("SINGLE") // SINGLE, MULTIPLE
  isRequired  Boolean      @default(false)
  isActive    Boolean      @default(true)
  minSelect   Int          @default(0)
  maxSelect   Int          @default(1)
  sortOrder   Int          @default(0)
  item        Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  options     ItemOption[]
}

model ItemOption {
  id          Int             @id @default(autoincrement())
  groupId     Int
  name        String
  nameEn      String?         // English translation
  price       Decimal         @default(0) @db.Decimal(10, 2)
  isDefault   Boolean         @default(false)
  isAvailable Boolean         @default(true)
  sortOrder   Int             @default(0)
  group       ItemOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

// --- Order Management ---
model Order {
  id             Int         @id @default(autoincrement())
  orderNumber    String      @unique // Professional ID (e.g., ORD-1001)
  customerName   String
  customerPhone  String
  customerId     Int?        // Link to Customer record if available
  orderType      String      // dine_in, takeaway, delivery
  status         String      @default("pending") // pending, confirmed, preparing, ready, in_route, delivered, cancelled, waiting_cancellation
  
  paymentStatus  String      @default("unpaid") // paid, unpaid
  paymentMethod  String      @default("cash")   // cash, card, online
  
  subtotal       Decimal     @default(0) @db.Decimal(10, 2)
  deliveryFee    Decimal     @default(0) @db.Decimal(10, 2)
  discount       Decimal     @default(0) @db.Decimal(10, 2)
  tax            Decimal     @default(0) @db.Decimal(10, 2)
  total          Decimal     @default(0) @db.Decimal(10, 2)
  
  tenantId       String?     @default("default-restaurant") // 🏢 Multi-tenant support
  
  address        String?
  notes          String?
  estimatedReadyAt DateTime?
  
  rating         Int?
  ratingComment  String?
  isRatingApproved Boolean @default(false)
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  
  orderItems     OrderItem[]
  customer       Customer?   @relation(fields: [customerId], references: [id])
  payment        Payment?
  cancellation   OrderCancellation?
  auditLogs      OrderAuditLog[]
  branch         String?     // Madina St, Khalda
  version        Int         @default(1)

  // 🚚 Delivery Snapshot (Production-grade Integrity)
  deliveryZoneId    String?
  deliveryZoneName  String?
  deliveryMinOrder  Decimal?   @db.Decimal(10, 2)

  @@index([status])
  @@index([customerPhone])
  @@index([customerId])
  @@index([createdAt])
  @@index([orderNumber])
  @@index([tenantId])
}

// 📦 Event Store — The Source of Truth
model Event {
  id            String   @id @default(uuid())
  type          String   // e.g., "order.created"
  aggregateId   Int      // The ID of the order
  aggregateType String   @default("order")
  payload       Json     // Full snapshot or delta
  metadata      Json?    // User info, IP, source
  version       Int      // Sequential version of the aggregate
  tenantId      String?  @default("default-restaurant")
  createdAt     DateTime @default(now())

  @@index([aggregateId])
  @@index([type])
  @@index([tenantId])
  @@index([createdAt])
}

model OrderItem {
  id              Int     @id @default(autoincrement())
  orderId         Int
  itemId          Int?
  itemName        String  // Snapshot name in case it changes later
  itemNameEn      String? // Snapshot English name
  quantity        Int     @default(1)
  unitPrice       Decimal     @db.Decimal(10, 2)
  selectedOptions String? // JSON stringized details of chosen options
  selectedOptionsEn String? // JSON stringized details of chosen options in English
  lineTotal       Decimal     @db.Decimal(10, 2)
  notes           String?
  
  order           Order   @relation(fields: [orderId], references: [id])
  item            Item?   @relation(fields: [itemId], references: [id], onDelete: SetNull)
  status          OrderItemStatus @default(normal)
  rejectionReason String?
}

enum OrderItemStatus {
  normal
  pending_partial_cancel
  cancelled
  rejected
}

// --- CRM & Payments ---
model Customer {
  id                Int       @id @default(autoincrement())
  uuid              String    @unique @default(uuid())
  name              String
  username          String?   @unique
  phone             String    @unique
  email             String?
  address           String?
  fcmToken          String?
  points            Int       @default(0)
  cancellationCount Int       @default(0)
  
  isBlacklisted     Boolean   @default(false)
  blacklistedAt     DateTime?
  blacklistExpiresAt DateTime? // New standard
  blacklistUntil    DateTime? // Compatibility fallback (Single Source of Truth layer)
  blacklistReason   String?
  blacklistReasonCode String?   // Classification
  blacklistSource   String?   // 'MANUAL' | 'AUTO' | 'SYSTEM'
  blacklistedBy     String?   // Admin ID or System
  blacklistSeverity String    @default("LOW") // LOW, MEDIUM, HIGH
  riskScore         Float     @default(0)   // Calculated score 0-100
  riskScoreUpdatedAt DateTime?
  
  createdAt         DateTime  @default(now())
  orders            Order[]
  auditLogs         CustomerAuditLog[]

  @@index([isBlacklisted])
}

model Payment {
  id             Int       @id @default(autoincrement())
  orderId        Int       @unique
  method         String
  amount         Decimal   @db.Decimal(10, 2)
  status         String    // completed, pending, failed
  transactionRef String?
  paidAt         DateTime?
  order          Order     @relation(fields: [orderId], references: [id])
}

// --- Security & Logging Removed ---

// --- Notifications ---
model Notification {
  id             Int      @id @default(autoincrement())
  customerPhone  String?  // If null, it's an admin notification
  title          String
  titleEn        String?
  message        String
  messageEn      String?
  type           String   // e.g. 'order_created', 'order_status', 'broadcast'
  isRead         Boolean  @default(false)
  orderId        Int?
  targetRoute    String?
  
  // --- 🛰️ SRE Reliability Fields ---
  status         String   @default("PENDING") // PENDING, SENT, FAILED, DEAD
  socketSent     Boolean  @default(false)
  fcmSent        Boolean  @default(false)
  retryCount     Int      @default(0)
  lastError      String?
  metadata       Json?    // Store payload for retries
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([customerPhone])
  @@index([status])
  @@index([createdAt])
}

// --- Reviews ---
model Review {
  id          Int      @id @default(autoincrement())
  itemId      Int
  customerName String
  rating      Int      // 1 to 5
  comment     String?
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model OrderCancellation {
  id             Int      @id @default(autoincrement())
  orderId        Int      @unique
  reason         String
  cancelledBy    String   // 'customer', 'admin', 'support'
  previousStatus String   // status before cancellation
  status         String   @default("pending") // pending, approved, rejected
  rejectionReason String?
  adminName      String?
  createdAt      DateTime @default(now())
  order          Order    @relation(fields: [orderId], references: [id])
}

model SystemSettings {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  freeCancelWindowMinutes Int  @default(5)
  spamCancelLimit         Int  @default(3)
  spamTimeWindowMinutes   Int  @default(30)
  defaultDeliveryFee      Decimal @default(1.00) @db.Decimal(10, 2)
}

model OrderAuditLog {
  id              Int      @id @default(autoincrement())
  orderId         Int
  eventType       String   // e.g., 'ORDER_CANCELLATION', 'ORDER_STATUS_CHANGE'
  eventAction     String   // e.g., 'APPROVED', 'REJECTED', 'REQUESTED', 'UPDATED'
  changedBy       String   // phone or email
  changedByRole   String   // 'customer', 'admin'
  previousData    String?  // JSON Snapshot 
  newData         String?  // JSON Snapshot 
  changedFields   String?  // JSON Array of field names that changed
  rejectionReason String?  // Specific field for quick filtering
  integrityHash   String?  // SHA256 mashup for security
  createdAt       DateTime @default(now())
  
  order           Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([createdAt])
  @@index([eventType])
}

model OrderAuditLogArchive {
  id              Int      @id @default(autoincrement())
  orderId         Int
  eventType       String
  eventAction     String
  changedBy       String
  changedByRole   String
  previousData    String?
  newData         String?
  changedFields   String?
  rejectionReason String?
  integrityHash   String?
  createdAt       DateTime @default(now())
}

model IdempotencyRecord {
  id           Int      @id @default(autoincrement())
  key          String   @unique
  status       String   @default("processing") // processing, completed, failed
  responseCode Int?
  responseBody String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([expiresAt])
}

model NotificationLog {
  id              Int      @id @default(autoincrement())
  orderId         Int
  customerId      Int?
  type            String   // e.g., 'CANCELLATION_APPROVED'
  status          String   @default("pending") // pending, sent, failed
  error           String?
  retries         Int      @default(0)
  maxRetries      Int      @default(3)
  nextRetryAt     DateTime?
  createdAt       DateTime @default(now())
}

model CustomerAuditLog {
  id              Int      @id @default(autoincrement())
  customerId      Int
  eventType       String   // e.g., 'BLACKLIST_MANUAL', 'BLACKLIST_AUTO', 'UNBLOCK'
  eventAction     String   // e.g., 'BLOCKED', 'UNBLOCKED'
  changedBy       String   // admin email or system
  changedByRole   String   // 'admin' or 'system'
  reason          String?
  previousData    String?  // JSON Snapshot
  newData         String?  // JSON Snapshot
  diff            String?  // JSON Patch or similar
  severitySnapshot String? // Severity at time of log
  requestId       String?  // E2E Tracking ID
  actionCategory  String   @default("CUSTOMER_MODERATION") // RISK_MANAGEMENT, etc.
  userAgent       String?
  deviceId        String?
  requestSource   String?  // 'admin_panel' | 'mobile_app'
  ip              String?
  createdAt       DateTime @default(now())
  
  customer        Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([createdAt])
}
model DeliveryZone {
  id        String   @id @default(uuid())
  nameAr    String   @unique
  nameEn    String?
  fee       Decimal  @db.Decimal(10, 2)
  minOrder  Decimal? @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   // UUID (can be User or Customer)
  role      String   // admin or customer
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)

  @@index([userId])
  @@index([token])
}

// --- Observability & Metrics ---
model HealthMetric {
  id              Int      @id @default(autoincrement())
  score           Int      // Global normalized score (0-100)
  status          String   // HEALTHY, DEGRADED, CRITICAL
  services        Json     // { db: "ok", redis: "down", ... }
  latencies       Json     // { db: 12, redis: 4, fcm: 150 }
  errorRate       Float?   // Percentage of failed health checks in last window
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([status])
}
